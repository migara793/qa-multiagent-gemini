FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for pygit2 and git
RUN apt-get update && \
    apt-get install -y \
        git \
        libgit2-dev \
        pkg-config \
        build-essential \
        libssl-dev \
        libffi-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements_v2.txt requirements.txt

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY analyzer_v2.py analyzer.py
COPY build_parsers.py .
COPY api.py .

# Build tree-sitter language parsers
RUN python build_parsers.py

# Verify build
RUN ls -lh build/languages.so || echo "Warning: Language library not built"

# Expose API port
EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import requests; requests.get('http://localhost:8001/health')" || exit 1

# Run the API server
CMD ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8001"]
